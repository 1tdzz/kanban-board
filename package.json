{
  "name": "kanban-board",
  "version": "1.0.0",
  "description": "Kanban board (React + Express + SQLite)",
  "private": true,
  "type": "commonjs",
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently -n server,client -c blue,green \"npm run dev -w server\" \"npm run dev -w client\"",
    "dev:server": "npm run dev -w server",
    "dev:client": "npm run dev -w client"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
